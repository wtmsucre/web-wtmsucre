---

---

<section id="actividad" class="bg-white border-b-2 border-[#0F1A2B]">
  <div class="max-w-6xl mx-auto px-7 py-20 md:py-24">
    <!-- Header -->
    <div class="grid md:grid-cols-[1.4fr_0.6fr] gap-10 items-end mb-14">
      <div>
        <div
          class="inline-flex items-center gap-2 font-mono text-xs lg:text-sm uppercase tracking-[0.18em] text-[#1F6FE5] mb-4"
        >
          <span class="w-[18px] h-0.5 bg-[#1F6FE5] flex-shrink-0"></span>
          Actividad · Mayo 2026
        </div>
        <h2
          class="font-google font-bold text-4xl lg:text-6xl leading-none tracking-tight text-[#0F1A2B] mb-4"
        >
          El Mural de Mamá.
        </h2>
        <p
          class="text-base lg:text-2xl text-[#3C4A5E] leading-relaxed max-w-[600px]"
        >
          Cada año, en Sucre, recordamos a las heroínas de la batalla de La
          Coronilla el 27 de mayo. Este año queremos celebrar también a las
          heroínas de cada casa. Construye con nosotras el mural colaborativo
          más grande del Día de la Madre.
        </p>
      </div>

      <!-- Poster -->
      <div
        class="p-7 border-2 border-[#0F1A2B] rounded-2xl flex flex-col items-center gap-2.5 text-center -rotate-1"
        style="background: rgba(236,106,139,0.12); box-shadow: 6px 6px 0 #0F1A2B;"
      >
        <span
          class="bg-[#0F1A2B] text-[#EC6A8B] font-google font-bold text-sm lg:text-xl tracking-wide px-4 py-1.5 rounded-full"
        >
          ¡HAGÁMOSLO!
        </span>
        <svg
          width="72"
          height="72"
          viewBox="0 0 12 12"
          shape-rendering="crispEdges"
          aria-hidden="true"
        >
          <g fill="#EC6A8B">
            <rect x="4" y="0" width="4" height="1"></rect>
            <rect x="3" y="1" width="6" height="1"></rect>
            <rect x="2" y="2" width="8" height="1"></rect>
            <rect x="2" y="3" width="8" height="1"></rect>
            <rect x="3" y="4" width="6" height="1"></rect>
            <rect x="4" y="5" width="4" height="1"></rect>
          </g>
          <g fill="#B94767">
            <rect x="4" y="2" width="2" height="2"></rect>
          </g>
          <g fill="#10A37F">
            <rect x="5" y="6" width="1" height="1"></rect>
            <rect x="3" y="7" width="4" height="1"></rect>
            <rect x="2" y="8" width="1" height="1"></rect>
            <rect x="4" y="8" width="2" height="1"></rect>
            <rect x="5" y="9" width="2" height="1"></rect>
            <rect x="5" y="10" width="2" height="1"></rect>
            <rect x="6" y="11" width="1" height="1"></rect>
          </g>
        </svg>
        <div
          class="font-mono font-bold text-base lg:text-xl text-[#0F1A2B] tracking-[0.08em]"
        >
          27 · 05 · 2026
        </div>
      </div>
    </div>

    <!-- CTA bar -->
    <div
      class="flex items-center gap-4 flex-wrap px-6 py-5 border-2 border-dashed border-[#0F1A2B] rounded-2xl"
      style="background: rgba(31,111,229,0.05);"
    >
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLSdDntrgYkaurFk-9M8PBBs10pALf5QY5vooFEYVkpc8MO5RhQ/viewform"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-[22px] py-3.5 bg-[#EC6A8B] text-white font-semibold text-base lg:text-xl rounded-full border-2 border-[#B94767] hover:-translate-x-px hover:-translate-y-px transition-transform no-underline"
        style="box-shadow: 4px 4px 0 #B94767"
      >
        Subir mi foto y dedicatoria <span>→</span>
      </a>
      <span class="font-mono text-xs lg:text-base text-[#3C4A5E]">
        Se abre el formulario de WTM Sucre
      </span>
    </div>

    <!-- Steps grid -->
    <div class="grid md:grid-cols-3 gap-4 lg:gap-6 mt-12">
      {
        [
          {
            n: "01",
            icon: "📸",
            title: "Sube una foto con tu mamá",
            copy: "Vale una foto reciente, una de la infancia, un retrato hecho por ti — cualquier imagen que tenga a tu mami protagonizando.",
          },
          {
            n: "02",
            icon: "✍️",
            title: "Escribe tu dedicatoria",
            copy: "Una frase corta, un agradecimiento, un meme técnico, un poema. Lo que tu mamá merezca oír. Hasta 240 caracteres.",
          },
          {
            n: "03",
            icon: "💛",
            title: "Aparece en el mural",
            copy: "Lo publicamos en menos de 24 horas. Comparte el link con mamá y vela emocionarse el 27 de mayo.",
          },
        ].map((s) => (
          <div
            class="bg-white border-2 border-[#0F1A2B] rounded-2xl p-6 lg:p-8 flex flex-col gap-3"
            style="box-shadow: 6px 6px 0 #0F1A2B"
          >
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs lg:text-base font-bold text-[#1F6FE5] tracking-[0.08em]">
                {s.n}
              </span>
              <span class="text-3xl lg:text-4xl leading-none">{s.icon}</span>
            </div>
            <h3 class="font-google font-bold text-xl lg:text-3xl leading-snug tracking-tight text-[#0F1A2B]">
              {s.title}
            </h3>
            <p class="text-sm lg:text-xl text-[#3C4A5E] leading-relaxed">
              {s.copy}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
