---
import wtmLogo from "@/assets/events/md-26/wtm-logo.png"

interface Section {
  href: string
  label: string
}

interface Props {
  sections?: Section[]
}

const {
  sections = [
    { href: "#inicio", label: "Inicio" },
    { href: "#actividad", label: "Actividad" },
    { href: "#mural", label: "Mural" },
    { href: "#organizadoras", label: "Equipo" },
    { href: "#sobre", label: "Sobre" },
  ],
} = Astro.props
---

<nav
  class="sticky top-0 z-50 border-b border-[#0F1A2B]/10 relative"
  style="background: rgba(255,246,244,0.88); backdrop-filter: blur(10px);"
>
  <div
    class="max-w-6xl mx-auto px-7 py-3.5 flex items-center justify-between gap-6"
  >
    <a
      href="#inicio"
      class="flex items-center gap-3 no-underline text-[#0F1A2B]"
    >
      <img
        src={wtmLogo.src}
        alt="WTM Sucre"
        class="h-10 lg:h-12 w-auto block"
      />
      <div>
        <div
          class="font-google font-medium font-bold tracking-tight leading-tight text-sm lg:text-lg"
        >
          Women Techmakers
        </div>
        <div
          class="font-mono text-[12px] lg:text-sm text-[#1F6FE5] tracking-[0.18em] uppercase -mt-0.5"
        >
          Sucre · Bolivia
        </div>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-7 lg:gap-9">
      {
        sections.map((section) => (
          <a
            href={section.href}
            class="text-sm lg:text-base text-[#3C4A5E] font-medium hover:text-[#1F6FE5] transition-colors no-underline"
          >
            {section.label}
          </a>
        ))
      }
    </div>

    <!-- Mobile Hamburger Button -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col justify-between w-6 h-3.5 text-[#0F1A2B] focus:outline-none z-50 cursor-pointer"
      aria-label="Abrir menú"
    >
      <span
        class="w-full h-[2px] bg-current transition-all duration-300 origin-center line-1"
      ></span>
      <span class="w-full h-[2px] bg-current transition-all duration-300 line-2"
      ></span>
      <span
        class="w-full h-[2px] bg-current transition-all duration-300 origin-center line-3"
      ></span>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu"
    class="absolute top-full left-0 w-full bg-[#FFF6F4]/98 backdrop-blur-lg border-b border-[#0F1A2B]/10 transition-all duration-300 ease-in-out opacity-0 translate-y-[-10px] pointer-events-none md:hidden flex flex-col py-6 px-7 gap-4 shadow-xl"
  >
    {
      sections.map((section) => (
        <a
          href={section.href}
          class="text-base text-[#3C4A5E] font-medium hover:text-[#1F6FE5] transition-colors no-underline py-2 border-b border-[#0F1A2B]/5 last:border-none"
        >
          {section.label}
        </a>
      ))
    }
  </div>
</nav>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  if (menuToggle && mobileMenu) {
    // Toggle menu
    menuToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = mobileMenu.classList.contains("open");

      if (isOpen) {
        mobileMenu.classList.remove("open");
        menuToggle.classList.remove("open");
      } else {
        mobileMenu.classList.add("open");
        menuToggle.classList.add("open");
      }
    });

    // Close menu when clicking outside
    document.addEventListener("click", (event) => {
      const target = event.target as Node;
      if (
        mobileMenu.classList.contains("open") &&
        !mobileMenu.contains(target) &&
        !menuToggle.contains(target)
      ) {
        mobileMenu.classList.remove("open");
        menuToggle.classList.remove("open");
      }
    });

    // Close menu when clicking a link
    const links = mobileMenu.querySelectorAll("a");
    links.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.remove("open");
        menuToggle.classList.remove("open");
      });
    });
  }
</script>

<style>
  #mobile-menu.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  #menu-toggle.open .line-1 {
    transform: translateY(6px) rotate(45deg);
  }

  #menu-toggle.open .line-2 {
    opacity: 0;
    transform: scale(0);
  }

  #menu-toggle.open .line-3 {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>
