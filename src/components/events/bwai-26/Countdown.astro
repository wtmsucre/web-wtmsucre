---
import { Timer } from "./Timer"

const targetDate = new Date("2026-05-09T09:00:00-04:00")
const initialTime = targetDate.getTime() - Date.now()
---

<section class="flex flex-col items-start w-full" id="countdown">
  <div class="relative w-full pb-2 pr-2 lg:pr-3">
    <div
      class="absolute inset-0 bg-red-500 border-2 lg:border-3 border-black rounded-2xl lg:rounded-3xl translate-x-2 translate-y-2.5 lg:translate-y-4 lg:translate-x-4"
    >
      <div class="border-b-2 lg:border-b-3 border-black h-15"></div>
    </div>

    <div
      class="relative bg-white border-2 lg:border-3 border-black rounded-2xl lg:rounded-3xl overflow-hidden z-10"
    >
      <div
        class="border-b-2 lg:border-b-3 border-black h-15 flex items-center px-5 gap-1.5"
      >
        <span
          class="size-3 lg:size-5 rounded-full bg-red-500 border-2 border-black"
        ></span>
        <span
          class="size-3 lg:size-5 rounded-full bg-yellow-500 border-2 border-black"
        ></span>
        <span
          class="size-3 lg:size-5 rounded-full bg-green-500 border-2 border-black"
        ></span>
      </div>
      <div class="flex flex-col gap-2 p-4 lg:gap-8 lg:p-8">
        <div class="flex gap-2 items-center">
          <span class="size-2 rounded-full bg-red-500 lg:size-4"></span>
          <p class="font-bold text-xs lg:text-xl tracking-widest">
            CUENTA REGRESIVA
          </p>
        </div>
        <p
          class="font-bold text-xl tracking-tight leading-tight lg:text-4xl"
        >
          Faltan para comenzar
        </p>
        <div class="w-full mt-1">
          <div class="lg:hidden">
            <Timer
              client:load
              initialTime={initialTime}
              targetDate={targetDate}
              labels={{
                days: "DÍAS",
                hours: "HRS",
                minutes: "MIN",
                seconds: "SEG",
              }}
            />
          </div>

          <div class="hidden lg:block">
            <Timer
              client:load
              large={true}
              initialTime={initialTime}
              targetDate={targetDate}
              labels={{
                days: "DÍAS",
                hours: "HRS",
                minutes: "MIN",
                seconds: "SEG",
              }}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
