---
const imgFrame11 = "/assets/figma/25fa6f2ec330ca82cc95ed739f17608f042f2cd1.svg"
const imgVector2 = "/assets/figma/b2d47073e64fc9b9e2deb21ae51e238454dee982.svg"
const imgVector3 = "/assets/figma/b237cd880d82dd7045df2032b2be5f68737c56d4.svg"
const imgVector4 = "/assets/figma/46d6a10d60e2901a8167dab2bba206d12b097912.svg"

const features = [
  {
    icon: imgFrame11,
    iconClass: "w-17 h-9",
    title: "Código real",
    desc: "Talleres prácticos con Gemini, AI Studio y Genkit que puedes llevar a tu proyecto el lunes.",
  },
  {
    icon: imgVector2,
    iconClass: "w-9 h-9",
    title: "Charlas clave",
    desc: "Speakers locales e invitados compartiendo lo que aprendieron construyendo con IA.",
  },
  {
    icon: imgVector3,
    iconClass: "w-20 h-8 lg:w-28 lg:h-10",
    title: "Comunidad",
    desc: "Dos días para conectar con la comunidad dev de Sucre y la región. Networking real.",
  },
  {
    icon: imgVector4,
    iconClass: "w-20 h-12 lg:w-16 lg:h-10",
    title: "Hecho en Sucre",
    desc: "Organizado por la comunidad, con el apoyo de SIB Chuquisaca y CISICH. Gratis y abierto.",
  },
]
---

<section class="w-full flex flex-col items-start px-5 py-8 gap-4 lg:px-20 lg:py-24 lg:gap-16">

  <h2 class="bg-white border-2 border-black rounded-xs md:rounded-lg px-2 py-1 text-xs font-bold lg:px-10 lg:py-4 lg:text-4xl">
    ¿QUÉ ES?
  </h2>

  <div class="flex flex-col gap-4 lg:gap-16 w-full">

    <div class="flex flex-col gap-2 lg:gap-6">
      <h2 class="font-bold text-4xl tracking-tight leading-tight lg:text-6xl">Build with AI</h2>
      <p class="text-[#3b3b3b] text-base leading-5.5 lg:text-2xl lg:leading-7.5 lg:max-w-4xl">
        Build with AI es la serie global de Google Developer Groups donde developers, estudiantes y curiosos nos juntamos para aprender IA en modo hands-on: desde prompt engineering hasta desplegar agentes con Gemini.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2 lg:gap-y-4 lg:gap-x-22 lg:max-w-300">
      {features.map(f => (
        <div class="bg-white border-2 lg:border-4 border-black flex flex-col gap-2 lg:gap-3 items-start p-5 lg:p-6 rounded-2xl lg:rounded-3xl">
          <img alt="" class={`${f.iconClass}`} src={f.icon} />
          <h3 class="font-bold text-xl lg:text-3xl tracking-tight">{f.title}</h3>
          <p class="text-[#3b3b3b] text-xs leading-5 lg:text-2xl lg:leading-7.5">{f.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>