---

---

<section id="eventos" class="bg-[#060D1C] px-6 py-20 lg:py-28">
  <div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 mb-5">
        <span class="w-8 h-px bg-[#FFBA00]"></span>
        <span
          class="font-grotesk text-[#FFBA00] text-xs tracking-[0.22em] uppercase"
          >2026</span
        >
        <span class="w-8 h-px bg-[#FFBA00]"></span>
      </div>
      <h2
        class="font-grotesk font-extrabold text-white text-3xl md:text-4xl lg:text-5xl tracking-tight mb-3"
      >
        Eventos pasados
      </h2>
      <p
        class="font-grotesk text-[#9CA3AF] text-sm lg:text-base tracking-widest"
      >
        Conecta · aprende · participa
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- IWD-26: Break the Pattern -->
      <a
        href="/eventos/iwd-26"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative rounded-2xl overflow-hidden flex flex-col justify-between min-h-[400px] no-underline transition-transform duration-300 hover:-translate-y-1"
        style="background: linear-gradient(145deg, #1565C0 0%, #1976D2 55%, #1452A4 100%);"
      >
        <!-- Gold top accent bar -->
        <div class="absolute top-0 left-0 right-0 h-1 bg-[#ebb842]"></div>

        <!-- Dot grid decoration (bottom-right) -->
        <div
          class="absolute bottom-0 right-0 w-40 h-40 opacity-10"
          style="background-image: radial-gradient(circle, #ebb842 1.5px, transparent 1.6px); background-size: 14px 14px;"
          aria-hidden="true"
        >
        </div>

        <!-- Glow -->
        <div
          class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          style="background: radial-gradient(ellipse at 30% 20%, rgba(235,184,66,0.18), transparent 60%);"
          aria-hidden="true"
        >
        </div>

        <!-- Content -->
        <div class="relative z-10 p-8 lg:p-10 flex flex-col h-full gap-8">
          <!-- Top -->
          <div class="flex-1">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 mb-6">
              <span
                class="font-grotesk font-semibold text-[#ebb842] text-xs tracking-[0.22em] uppercase px-3 py-1.5 rounded-full border border-[#ebb842]/40"
                style="background: rgba(235,184,66,0.12);"
              >
                IWD · 2026
              </span>
            </div>

            <!-- Title -->
            <h3
              class="font-grotesk font-extrabold text-white leading-none tracking-tight mb-4"
              style="font-size: clamp(2rem, 5vw, 2.75rem);"
            >
              Break the<br />
              <span class="text-[#ebb842]">Pattern.</span>
            </h3>

            <!-- Description -->
            <p
              class="font-grotesk text-white/70 text-sm lg:text-base leading-relaxed max-w-[280px]"
            >
              Día Internacional de la Mujer en tecnología. Charlas técnicas,
              networking y workshops para romper barreras.
            </p>
          </div>

          <!-- Bottom -->
          <div class="flex items-end justify-between gap-4">
            <div>
              <div
                class="font-grotesk text-white/50 text-xs tracking-widest uppercase mb-1"
              >
                Fecha
              </div>
              <div class="font-grotesk font-semibold text-white text-sm">
                7 de marzo · Sucre
              </div>
            </div>
            <div
              class="flex items-center gap-2 font-grotesk font-semibold text-[#ebb842] text-sm group-hover:gap-3 transition-all"
            >
              Ver evento
              <span class="text-lg leading-none">→</span>
            </div>
          </div>
        </div>
      </a>

      <!-- MD-26: Mural de Mamá -->
      <a
        href="/eventos/md-26"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative rounded-2xl overflow-hidden flex flex-col justify-between min-h-[400px] no-underline transition-transform duration-300 hover:-translate-y-1"
        style="background: #FFF6F4;"
      >
        <!-- Pink dot pattern -->
        <div
          class="absolute inset-0"
          style="background-image: radial-gradient(circle, rgba(236,106,139,0.22) 1.5px, transparent 1.6px); background-size: 22px 22px; background-color: #FFF6F4;"
          aria-hidden="true"
        >
        </div>

        <!-- Warm gradient wash at top -->
        <div
          class="absolute top-0 left-0 right-0 h-40 opacity-60"
          style="background: linear-gradient(180deg, rgba(255,246,244,1) 0%, transparent 100%);"
          aria-hidden="true"
        >
        </div>

        <!-- Pink glow on hover -->
        <div
          class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl"
          style="background: radial-gradient(ellipse at 70% 80%, rgba(236,106,139,0.15), transparent 60%);"
          aria-hidden="true"
        >
        </div>

        <!-- Navy top accent bar -->
        <div class="absolute top-0 left-0 right-0 h-1 bg-[#0F1A2B]"></div>

        <!-- Content -->
        <div class="relative z-10 p-8 lg:p-10 flex flex-col h-full gap-8">
          <!-- Top -->
          <div class="flex-1">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 mb-6">
              <span
                class="font-grotesk font-semibold text-[#EC6A8B] text-xs tracking-[0.22em] uppercase px-3 py-1.5 rounded-full border border-[#EC6A8B]/40"
                style="background: rgba(236,106,139,0.10);"
              >
                MD · 2026
              </span>
            </div>

            <!-- Title -->
            <h3
              class="font-grotesk font-extrabold text-[#0F1A2B] leading-none tracking-tight mb-4"
              style="font-size: clamp(2rem, 5vw, 2.75rem);"
            >
              Mural<br />
              <em class="not-italic" style="color: #EC6A8B;">de Mamá.</em>
            </h3>

            <!-- Description -->
            <p
              class="font-grotesk text-[#3C4A5E] text-sm lg:text-base leading-relaxed max-w-[280px]"
            >
              El mural colaborativo más grande del Día de la Madre. Sube una
              foto con tu mami y sé parte de la historia.
            </p>
          </div>

          <!-- Bottom -->
          <div class="flex items-end justify-between gap-4">
            <div>
              <div
                class="font-grotesk text-[#3C4A5E]/60 text-xs tracking-widest uppercase mb-1"
              >
                Fecha
              </div>
              <div class="font-grotesk font-semibold text-[#0F1A2B] text-sm">
                Mayo · Sucre
              </div>
            </div>
            <div
              class="flex items-center gap-2 font-grotesk font-semibold text-[#0F1A2B] text-sm group-hover:gap-3 transition-all"
            >
              Ver evento
              <span class="text-lg leading-none">→</span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
