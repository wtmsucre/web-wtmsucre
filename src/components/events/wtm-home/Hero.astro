---

---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center text-center overflow-hidden px-6 py-24 bg-[#0A1229]"
>
  <div
    class="absolute inset-0 z-0"
    style="
      background-image:
        linear-gradient(rgba(99,130,255,0.07) 1px, transparent 1px),
        linear-gradient(90deg, #d1d93d12 1px, transparent 1px);
      background-size: 48px 48px;
    "
    aria-hidden="true"
  >
  </div>

  <div
    class="absolute inset-0 z-1"
    style="background: radial-gradient(ellipse 80% 70% at 50% 50%, transparent 40%, #0A1229 100%);"
    aria-hidden="true"
  >
  </div>

  <!-- Floating dots -->
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-55"
    style="width:8px;height:8px;top:12%;left:14%;"
    aria-hidden="true"></span>
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-55"
    style="width:5px;height:5px;top:18%;right:18%;"
    aria-hidden="true"></span>
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-35"
    style="width:12px;height:12px;top:38%;left:8%;"
    aria-hidden="true"></span>
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-55"
    style="width:6px;height:6px;bottom:28%;left:20%;"
    aria-hidden="true"></span>
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-55"
    style="width:5px;height:5px;bottom:22%;right:14%;"
    aria-hidden="true"></span>
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-40"
    style="width:7px;height:7px;top:55%;right:8%;"
    aria-hidden="true"></span>
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-55"
    style="width:4px;height:4px;top:8%;right:40%;"
    aria-hidden="true"></span>
  <span
    class="absolute z-2 bg-[#FFBA00] opacity-30"
    style="width:6px;height:6px;bottom:40%;left:42%;"
    aria-hidden="true"></span>

  <div class="relative z-3 max-w-5xl mx-auto">
    <div
      class="inline-flex items-center gap-2 border border-white/10 rounded-full px-4 py-1.5 mb-8"
      style="background: rgba(255,255,255,0.06); backdrop-filter: blur(4px);"
    >
      <span class="w-2 h-2 rounded-full bg-[#FFBA00] animate-pulse shrink-0"
      ></span>
      <span class="text-[#D1D5DB] text-sm font-grotesk font-medium"
        >Women Techmakers · Sucre, Bolivia</span
      >
    </div>

    <h1
      class="font-grotesk font-extrabold text-white text-4xl md:text-5xl lg:text-[72px] leading-[1.1] tracking-tight mb-6"
    >
      La comunidad tech femenina más <span class="text-[#FFBA00]">moderna</span> de
      Sucre.
    </h1>

    <p
      class="font-grotesk text-[#9CA3AF] leading-relaxed max-w-xl mx-auto mb-10"
      style="font-size: clamp(0.95rem, 1.8vw, 1.1rem);"
    >
      Aprendemos, construimos y lideramos. Eventos, workshops y mentoría para
      impulsar a mujeres en tecnología — desde estudiantes hasta profesionales.
    </p>

    <div class="flex items-center justify-center gap-4 flex-wrap">
      <a
        href="#eventos"
        class="inline-flex items-center gap-2 bg-[#FFBA00] hover:bg-[#FFC93C] text-[#0A1229] font-grotesk font-bold text-base px-7 py-3.5 rounded-full transition-colors no-underline"
      >
        Ver eventos
        <span aria-hidden="true">→</span>
      </a>

      <!-- <a
        href="#eventos"
        class="inline-flex items-center gap-2 text-white font-grotesk font-semibold text-base px-7 py-3.5 rounded-full border border-white/15 transition-colors no-underline hover:bg-white/10 hover:border-white/25"
        style="background: rgba(255,255,255,0.06); backdrop-filter: blur(4px);"
      >
        Ver eventos
      </a> -->
    </div>
  </div>
</section>
